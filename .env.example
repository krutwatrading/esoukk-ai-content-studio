# Shopify Dev Dashboard app — keep actual values only in .env.local / Vercel
SHOPIFY_SHOP=12dafb
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Used to verify Shopify webhook signatures. This is the same app client secret.
SHOPIFY_API_VERSION=2026-07

# Optional paid AI features
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1

ALLOWED_SHOPIFY_DOMAINS=esoukk.ae,www.esoukk.ae

# Supabase (prefer current publishable/secret keys)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SITE_URL=https://ai.esoukk.ae

# Meta publishing (Phase 4)
META_APP_ID=
META_APP_SECRET=
# Generate at least 32 random bytes; used server-side to encrypt social tokens.
SOCIAL_TOKEN_ENCRYPTION_KEY=
META_GRAPH_API_VERSION=v25.0
